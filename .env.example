# File description:
# This file documents the environment variables required to run the dashboard locally or in production.
# Copy values into .env.local for local development, but never commit real credentials.

# Public Supabase browser-safe settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase key used by sync routes. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret used by Vercel Cron when calling /api/cron/hourly-sync.
CRON_SECRET=

# Set true only for local UI review without live Supabase/platform credentials.
DEMO_MODE=true

# Optional API revision overrides.
KLAVIYO_REVISION=2026-04-15
SHOPIFY_API_VERSION=2026-07

# JSON array of region connection settings. Keep all tokens server-only.
REGION_CONFIG_JSON='[
  {
    "slug": "us",
    "name": "United States",
    "currencyCode": "USD",
    "timezone": "America/New_York",
    "shopifyShopDomain": "example.myshopify.com",
    "shopifyAdminAccessToken": "shpat_xxx",
    "klaviyoPrivateKey": "pk_xxx",
    "klaviyoAccountLabel": "US Klaviyo",
    "klaviyoConversionMetricId": ""
  }
]'
